##############################################################################
#
#  Gradle start up script for UN*X
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
PRG="$0"
while [ -h "$PRG" ]; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=`dirname "$PRG"`/"$link"
    fi
done
SAVED="$PWD"
cd "$(dirname "$PRG")/" >&- 2>&-
APP_HOME="$(pwd -P)"
cd "$SAVED" >&- 2>&-

APP_NAME="Gradle"
APP_BASE_NAME=`basename "$0"`

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS=""

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD="maximum"

warn () {
    echo "$*"
}

die () {
    echo
    echo "ERROR: $*"
    echo
    exit 1
}

# OS specific support (must be 'true' or 'false').
cygwin=false
darwin=false
mingw=false
case "`uname`" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MINGW* )
    mingw=true
    ;;
esac

# For Cygwin, ensure paths are in UNIX format before anything is touched.
if $cygwin ; then
    [ -n "$JAVA_HOME" ] && JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
    [ -n "$CLASSPATH" ] && CLASSPATH=`cygpath --path --unix "$CLASSPATH"`
fi

# Attempt to find JAVA_HOME if it's not set.
if [ -z "$JAVA_HOME" ] ; then
    if $darwin ; then
        # OSX
        if [ -x "/usr/libexec/java_home" ] ; then
            export JAVA_HOME=`/usr/libexec/java_home`
        else
            warn "JAVA_HOME not set; falling back to system JVM"
        fi
    elif $mingw ; then
        # Windows MinGW
        JAVA_HOME="$JAVA_HOME"
    else
        # Linux
        if [ -x "/usr/bin/java" ] ; then
            JAVA_HOME="/usr"
        else
            warn "JAVA_HOME not set; falling back to system JVM"
        fi
    fi
fi

# Ensure that JAVA_HOME exists
export JAVA_HOME="$JAVA_HOME"
if [ -z "$JAVA_HOME" ] ; then
    die "JAVA_HOME not set and cannot be determined"
fi

if [ ! -d "$JAVA_HOME" ] ; then
    die "JAVA_HOME directory does not exist: $JAVA_HOME"
fi

JAVA_EXE="$JAVA_HOME/bin/java"
if [ ! -x "$JAVA_EXE" ] ; then
    die "JAVA_HOME/bin/java does not exist or is not executable: $JAVA_EXE"
fi

# Set CLASSPATH if empty
if [ -z "$CLASSPATH" ] ; then
    CLASSPATH="$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
else
    CLASSPATH="$CLASSPATH:$APP_HOME/gradle/wrapper/gradle-wrapper.jar"
fi

# For Cygwin, switch paths to Windows format before running java
if $cygwin ; then
    APP_HOME=`cygpath --path --windows "$APP_HOME"`
    JAVA_HOME=`cygpath --path --windows "$JAVA_HOME"`
    CLASSPATH=`cygpath --path --windows "$CLASSPATH"`
    JAVA_EXE=`cygpath --unix "$JAVA_EXE"`

    # We build the pattern for arguments to be converted via cygpath
    ROOTDIRSRAW=`find "$APP_HOME" -type d -maxdepth 1 -not -name "*[!A-Za-z0-9_]" | head -20`
    SEP=""
    for dir in $ROOTDIRSRAW ; do
        ROOTDIRS="$ROOTDIRS$SEP$dir"
        SEP=";"
    done
    OURCYGPATTERN="(^($ROOTDIRS))"
    # Add a user-defined pattern to the cygpath arguments
    if [ -n "$GRADLE_CYGPATTERN" ] ; then
        OURCYGPATTERN="$OURCYGPATTERN|($GRADLE_CYGPATTERN)"
    fi
    # Now convert the arguments - kludge to limit ourselves to /bin/sh
    i=0
    for arg in "$@" ; do
        CHECK=`echo "$arg" | egrep -c "$OURCYGPATTERN" -`
        if [ $CHECK -ne 0 ] ; then
            NEWARG=`cygpath --path --windows "$arg"`
            # Escape spaces in converted paths
            NEWARG=`echo "$NEWARG" | sed 's/ /\\ /g'`
            args[$i]="$NEWARG"
        else
            args[$i]="$arg"
        fi
        i=$((i+1))
    done
    set -- "${args[@]}"
fi

# Split up the JVM_OPTS And GRADLE_OPTS values into an array, following the shell quoting and substitution rules
splitJvmOpts() {
    JVM_OPTS=("$@")
}

splitJvmOpts $DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS

# by default we should be in the correct project dir, but when run from Finder on Mac, the cwd is wrong
if [ "$(uname)" = "Darwin" ] && [ -z "$BUILD_NUMBER" ]; then
  cd "$(dirname "$0")" >&- 2>&-
fi

exec "$JAVA_EXE" "${JVM_OPTS[@]}" -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
