<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.cheaplive.capture">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Phase 1.5: 摄像头面捕是可选项，当前 APK 主要为离线 Avatar 演示 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- 普通变声（P1）：声明麦克风权限，运行时由用户主动触发请求，不自动请求 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:allowBackup="false"
        android:label="CheapLive Capture"
        android:theme="@style/Theme.CheapLiveCapture">

        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:label="CheapLive Capture"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AvatarDemoActivity"
            android:exported="false"
            android:label="Avatar 离线演示"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="面捕 / 多端会话 (开发中)"
            android:configChanges="orientation|screenSize|keyboardHidden" />
    </application>
</manifest>
